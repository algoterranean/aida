// AIDA server configuration — EXAMPLE.
// Copy to `Configs/AIDA/config.jsonc` on the server (or FactoryGame/Configs/AIDA/) and fill in.
// The apiKey field is SERVER-ONLY: the orchestrator reads it once at init; it never enters
// any replicated struct or client-reachable path. Never commit a real key (see .gitignore).
{
  "provider": {
    "type": "anthropic",                         // "openai-compatible" | "anthropic"
    "baseUrl": "https://api.anthropic.com",      // Anthropic shown; for Ollama/LAN use "openai-compatible" + "http://localhost:11434/v1".
    "apiKey": "",                                // SERVER-ONLY. Required for Anthropic; leave empty for keyless local endpoints.
    "model": "claude-sonnet-5",
    "maxOutputTokens": 32768,                    // a CAP, not a spend — big composite build specs are several KB of tool-call JSON; truncation mid-call loses the whole call
    "visionModel": ""                            // optional: model used for requests carrying reference images (empty = "model")
  },
  "limits": {
    "perPlayerPerMinute": 4,
    "globalPerMinute": 12,
    "maxToolRoundTrips": 5,
    "dailyTokenBudget": 0                         // 0 = unlimited
  },
  "permissions": {
    "chat": "everyone",
    "query": "everyone",
    "act": []                                     // allowlist of Epic account IDs, e.g. ["<epic-account-id>"]; use ["everyone"] to allow all (solo/trusting host)
  },
  "privacy": {
    "sendFactoryData": true,
    "sendPlayerNames": true,
    "sendChatHistoryDepth": 20,
    "logPromptsToSidecar": false
  },
  "snapshots": { "intervalMinutes": 30, "keep": 200 },
  "actions": {
    "enabled": true,                              // master kill-switch; off => propose_* tools not registered
    "ttlSeconds": 600,                            // proposal time-to-live awaiting approval
    "approvalPolicy": "any-act",                  // "any-act" | "requester" | ["<epic-account-id>", ...]
    "maxProposalItems": 0,                        // cap on placements per proposal; 0 = unlimited
    "maxPendingProposals": 3,
    "batchPerTick": 10,                           // executor slice size (10 Hz)
    "undoWindow": 25,                             // how far back /aida undo may reach
    "costMode": "central",                        // "central" (deduct vs central storage) | "free"
    "allowDirectFuseReset": true,                 // reset_fuse acts immediately; false disables it
    "announceProposals": false                    // echo "AIDA proposes ..." into chat (card+ghost already show it)
  },
  // P8 standing tasks: "/aida task add \"<prompt>\" every 10m" — recurring READ-ONLY checks that
  // spend LLM tokens unattended, so they are opt-in and budgeted.
  "tasks": {
    "enabled": false,
    "minIntervalMinutes": 5,                      // floor on every task's interval
    "maxPerDay": 200                              // global LLM-run budget per UTC day
  },
  // Phase 5 reference-image uploads. PRIVACY: attached images are sent to the configured LLM
  // provider (that is the feature); "enabled": false is the server admin's off switch.
  "uploads": {
    "enabled": true,
    "maxImageBytes": 3145728,                     // per-image ceiling after client JPEG normalization
    "maxImagesPerMessage": 4,
    "maxImagesPerRequest": 4,                     // newest images across history attached per LLM request
    "maxDimension": 1568,                         // client downscale target (long edge, px)
    "maxStoredImages": 16,                        // server-RAM store cap (32 MiB total budget)
    "ttlSeconds": 600                             // unreferenced uploads expire; sent ones follow the transcript
  },
  // packEnabled appends the generated game data pack (recipes/buildings/logistics, ~15-25k tokens,
  // rebuilt every 5 min) to the system prompt so the model does rate/power/layout math without
  // lookup round-trips. Costs more per request unless the provider caches prompt prefixes.
  "prompts": { "systemPromptFile": "prompts/system.md", "toolsFile": "tools.json", "packEnabled": true }
}
